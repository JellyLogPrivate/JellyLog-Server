{
  "info": {
    "name": "JellyLog-Server API (Single File)",
    "_postman_id": "6d4d6d8d-7d41-4eb4-8c0a-4f0c0b0f5b11",
    "description": "Single-file Postman collection. Import only this file. No environment file needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userCode", "value": "3" },

    { "key": "foodCode", "value": "4" },
    { "key": "petCode", "value": "1" }
  ],
  "item": [
    {
      "name": "Food",
      "item": [
        {
          "name": "01 Init FoodCode (run first)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/foods"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (Array.isArray(body) && body.length > 0 && body[0].foodCode != null) {",
                  "  pm.collectionVariables.set('foodCode', String(body[0].foodCode));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Food By Code",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/foods/{{foodCode}}"
          }
        },
        {
          "name": "Create Food",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"foodName\": \"Apple Jelly\",\n  \"foodImage\": \"https://example.com/apple.png\",\n  \"foodPrice\": 100,\n  \"foodExp\": 25\n}"
            },
            "url": "{{baseUrl}}/api/foods",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const body = pm.response.json();",
                    "if (body && body.foodCode) {",
                    "  pm.collectionVariables.set('foodCode', String(body.foodCode));",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
        {
          "name": "Update Food",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"foodName\": \"Apple Jelly Plus\",\n  \"foodImage\": \"https://example.com/apple-plus.png\",\n  \"foodPrice\": 120,\n  \"foodExp\": 30\n}"
            },
            "url": "{{baseUrl}}/api/foods/{{foodCode}}"
          }
        },
        {
          "name": "Delete Food",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/foods/{{foodCode}}"
          }
        }
      ]
    },
    {
      "name": "Pet Master",
      "item": [
        {
          "name": "02 Init PetCode (run first)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pets"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (Array.isArray(body) && body.length > 0 && body[0].petCode != null) {",
                  "  pm.collectionVariables.set('petCode', String(body[0].petCode));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Pet By Code",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pets/{{petCode}}"
          }
        }
      ]
    },
    {
      "name": "User Pet",
      "item": [
        {
          "name": "03 Create User Pet (409 means already exists)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userCode\": {{userCode}},\n  \"petCode\": {{petCode}},\n  \"level\": 1,\n  \"exp\": 0,\n  \"emotion\": \"HAPPY\"\n}"
            },
            "url": "{{baseUrl}}/api/user-pets"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const code = pm.response.code;",
                  "pm.test('Create user pet: 201(created) or 409(already exists)', function () {",
                  "  pm.expect([201, 409]).to.include(code);",
                  "});",
                  "if (code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body && body.userCode != null) pm.collectionVariables.set('userCode', String(body.userCode));",
                  "  if (body && body.petCode != null) pm.collectionVariables.set('petCode', String(body.petCode));",
                  "}",
                  "if (code === 409) {",
                  "  console.log('User pet already exists. Continue with Get User Pet / Feed.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Pets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user-pets/users/{{userCode}}"
          }
        },
        {
          "name": "Get User Pet",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user-pets/{{userCode}}/{{petCode}}"
          }
        },
        {
          "name": "Update User Pet",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"level\": 2,\n  \"exp\": 150,\n  \"emotion\": \"HAPPY\"\n}"
            },
            "url": "{{baseUrl}}/api/user-pets/{{userCode}}/{{petCode}}"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "04 Create User Inventory (run after food init)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userCode\": {{userCode}},\n  \"foodCode\": {{foodCode}},\n  \"quantity\": 10\n}"
            },
            "url": "{{baseUrl}}/api/inventory"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const code = pm.response.code;",
                  "pm.test('Create inventory: 201(created) or 409(already exists) or 404(food missing)', function () {",
                  "  pm.expect([201, 409, 404]).to.include(code);",
                  "});",
                  "if (code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body && body.foodCode != null) pm.collectionVariables.set('foodCode', String(body.foodCode));",
                  "}",
                  "if (code === 409) {",
                  "  console.log('Inventory already exists. Continue with Feed.');",
                  "}",
                  "if (code === 404) {",
                  "  console.warn('foodCode not found. Run `01 Init FoodCode (run first)` and retry.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Inventory",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/{{userCode}}"
          }
        },
        {
          "name": "Get User Inventory Item",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/{{userCode}}/{{foodCode}}"
          }
        },
        {
          "name": "Update User Inventory",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 20\n}"
            },
            "url": "{{baseUrl}}/api/inventory/{{userCode}}/{{foodCode}}"
          }
        },
        {
          "name": "Delete User Inventory",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/inventory/{{userCode}}/{{foodCode}}"
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "05 Feed Pet",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userCode\": {{userCode}},\n  \"petCode\": {{petCode}},\n  \"foodCode\": {{foodCode}},\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/feed"
          }
        }
      ]
    }
  ]
}

